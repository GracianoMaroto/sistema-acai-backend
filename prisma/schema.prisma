generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  active       Boolean  @default(true)
  roleId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  refreshToken String?
  orders       Order[]  @relation("SellerOrders")
  role         Role     @relation(fields: [roleId], references: [id])
}

model Product {
  id          String           @id @default(uuid())
  name        String
  description String?
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  variants    ProductVariant[]
}

model ProductVariant {
  id             String          @id @default(uuid())
  stockQuantity  Int             @default(0)
  productId      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  name           String
  orderItems     OrderItem[]
  prices         ProductPrice[]
  product        Product         @relation(fields: [productId], references: [id])
  stockMovements StockMovement[]
}

model ProductPrice {
  id               String         @id @default(uuid())
  productVariantId String
  saleChannelId    String
  price            Decimal        @db.Decimal(10, 2)
  cost             Decimal        @db.Decimal(10, 2)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  saleChannel      SaleChannel    @relation(fields: [saleChannelId], references: [id])

  @@unique([productVariantId, saleChannelId])
}

model Customer {
  id           String   @id @default(uuid())
  name         String
  phone        String?
  email        String?  @unique
  street       String?
  number       String?
  city         String?
  state        String?
  neighborhood String?
  zipCode      String?
  complement   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model OrderStatus {
  id     String  @id @default(uuid())
  name   String  @unique
  orders Order[]
}

model PaymentStatus {
  id     String  @id @default(uuid())
  name   String  @unique
  orders Order[]
}

model DeliveryStatus {
  id     String  @id @default(uuid())
  name   String  @unique
  orders Order[]
}

model PaymentMethod {
  id       String    @id @default(uuid())
  name     String    @unique
  payments Payment[]
}

model SaleChannel {
  id            String         @id @default(uuid())
  name          String         @unique
  createdAt     DateTime       @default(now())
  modifierType  ModifierType?
  priceModifier Decimal?       @db.Decimal(10, 2)
  orders        Order[]
  productPrices ProductPrice[]
}

model Order {
  id               String          @id @default(uuid())
  orderDate        DateTime        @default(now())
  deliveryDate     DateTime?
  totalAmount      Decimal         @db.Decimal(10, 2)
  totalCost        Decimal         @db.Decimal(10, 2)
  totalProfit      Decimal         @db.Decimal(10, 2)
  sellerId         String
  customerId       String?
  orderStatusId    String
  paymentStatusId  String
  deliveryStatusId String
  saleChannelId    String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  customer         Customer?       @relation(fields: [customerId], references: [id])
  deliveryStatus   DeliveryStatus  @relation(fields: [deliveryStatusId], references: [id])
  orderStatus      OrderStatus     @relation(fields: [orderStatusId], references: [id])
  paymentStatus    PaymentStatus   @relation(fields: [paymentStatusId], references: [id])
  saleChannel      SaleChannel     @relation(fields: [saleChannelId], references: [id])
  seller           User            @relation("SellerOrders", fields: [sellerId], references: [id])
  items            OrderItem[]
  payments         Payment[]
  stockMovements   StockMovement[]
}

model OrderItem {
  id               String         @id @default(uuid())
  quantity         Int
  unitPrice        Decimal        @db.Decimal(10, 2)
  unitCost         Decimal        @db.Decimal(10, 2)
  orderId          String
  productVariantId String
  order            Order          @relation(fields: [orderId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
}

model StockMovement {
  id               String            @id @default(uuid())
  type             StockMovementType
  quantity         Int
  reason           String?
  productVariantId String
  orderId          String?
  createdAt        DateTime          @default(now())
  order            Order?            @relation(fields: [orderId], references: [id])
  productVariant   ProductVariant    @relation(fields: [productVariantId], references: [id])
}

model Payment {
  id              String        @id @default(uuid())
  amount          Decimal       @db.Decimal(10, 2)
  paymentDate     DateTime      @default(now())
  notes           String?
  orderId         String
  paymentMethodId String
  order           Order         @relation(fields: [orderId], references: [id])
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}

enum ModifierType {
  DISCOUNT
  MARKUP
}

enum StockMovementType {
  IN
  OUT
}
