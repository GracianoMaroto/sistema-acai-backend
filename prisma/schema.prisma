generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  passwordHash String
  active       Boolean @default(true)

  refreshToken String?

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  orders Order[] @relation("SellerOrders")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?
  active      Boolean @default(true)

  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id            String @id @default(uuid())
  name          String
  stockQuantity Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  prices     ProductPrice[]
  orderItems OrderItem[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
}

model ProductPrice {
  id String @id @default(uuid())

  productVariantId String
  saleChannelId    String

  price Decimal @db.Decimal(10, 2)
  cost  Decimal @db.Decimal(10, 2)

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  saleChannel    SaleChannel    @relation(fields: [saleChannelId], references: [id])

  @@unique([productVariantId, saleChannelId])
}

model Customer {
  id           String  @id @default(uuid())
  name         String
  phone        String?
  email        String? @unique
  street       String?
  neighborhood String?
  number       String?
  city         String?
  state        String?
  zipCode      String?
  complement   String?

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderStatus {
  id     String  @id @default(uuid())
  name   String  @unique
  orders Order[]
}

model PaymentStatus {
  id     String  @id @default(uuid())
  name   String  @unique
  orders Order[]
}

model DeliveryStatus {
  id     String  @id @default(uuid())
  name   String  @unique
  orders Order[]
}

model PaymentMethod {
  id       String    @id @default(uuid())
  name     String    @unique
  payments Payment[]
}

model SaleChannel {
  id            String        @id @default(uuid())
  name          String        @unique
  priceModifier Decimal?      @db.Decimal(10, 2)
  modifierType  ModifierType?
  createdAt     DateTime      @default(now())

  productPrices ProductPrice[]
  orders        Order[]
}

enum ModifierType {
  DISCOUNT
  MARKUP
}

model Order {
  id           String    @id @default(uuid())
  orderDate    DateTime  @default(now())
  deliveryDate DateTime?

  totalAmount Decimal @db.Decimal(10, 2)
  totalCost   Decimal @db.Decimal(10, 2)
  totalProfit Decimal @db.Decimal(10, 2)

  sellerId String
  seller   User   @relation("SellerOrders", fields: [sellerId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  orderStatusId String
  orderStatus   OrderStatus @relation(fields: [orderStatusId], references: [id])

  paymentStatusId String
  paymentStatus   PaymentStatus @relation(fields: [paymentStatusId], references: [id])

  deliveryStatusId String
  deliveryStatus   DeliveryStatus @relation(fields: [deliveryStatusId], references: [id])

  saleChannelId String
  saleChannel   SaleChannel @relation(fields: [saleChannelId], references: [id])

  items    OrderItem[]
  payments Payment[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int

  unitPrice Decimal @db.Decimal(10, 2)
  unitCost  Decimal @db.Decimal(10, 2)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
}

model StockMovement {
  id String @id @default(uuid())

  type     StockMovementType
  quantity Int

  reason String?

  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
}

enum StockMovementType {
  IN
  OUT
}

model Payment {
  id     String  @id @default(uuid())
  amount Decimal @db.Decimal(10, 2)

  paymentDate DateTime @default(now())
  notes       String?

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}
